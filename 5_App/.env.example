# 5_App 환경변수 템플릿 — 실제 값은 .env (정적 데모) 또는 .env.local (Next.js)에 넣으세요. 둘 다 git 제외됨.
# 복사: cp .env.example .env  후 값 채우기

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# 서버 전용(절대 클라이언트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── 소셜 로그인 OAuth ──
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
KAKAO_CLIENT_ID=YOUR_KAKAO_REST_API_KEY
KAKAO_CLIENT_SECRET=YOUR_KAKAO_CLIENT_SECRET
NAVER_CLIENT_ID=YOUR_NAVER_CLIENT_ID
NAVER_CLIENT_SECRET=YOUR_NAVER_CLIENT_SECRET

# ── 지도/기타 ──
# vworld WMS 배경지도 인증키 (https://www.vworld.kr). 사용 도메인 등록 필요(localhost·배포도메인).
# 정적 데모는 클라이언트에서 호출하므로 노출됨 — 반드시 도메인 잠금으로만 보호.
VWORLD_KEY=
NEXT_PUBLIC_MAP_STYLE_URL=

# ── 국립생물자원관 디지털 자료관 API (종 미디어·세밀화, 빌드타임 전용) ──
# 발급: https://species.nibr.go.kr  (OPEN API 신청 → 인증키 oapiAcsUnqNo + 접근서버 IP 등록)
# ⚠ 이 키는 빌드 스크립트(build_media_nibr.py)만 읽음. config.js(클라이언트)에 절대 주입 금지.
# ⚠ IP 화이트리스트 → 반드시 신청한 IP(빌드 PC)에서만 호출됨.
NIBR_DIGITAL_API_KEY=YOUR_OAPI_ACS_UNQ_NO
# 엔드포인트: 명세에 운영(species.nibr.go.kr)·상세표(msaspecies.coreit.co.kr)가 혼재 → 신청 시 확정값. 비우면 스크립트가 후보를 프로브.
NIBR_DIGITAL_API_URL=
